{
  "name": "mion-nuxt-starter",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "build:api": "vite build --config api/vite.config.ts",
    "build:api:node": "vite build --config api/vite.config.ts --ssr api/src/server.node.ts",
    "build:api:bun": "vite build --config api/vite.config.ts --ssr api/src/server.bun.ts",
    "build:api:vercel": "vite build --config api/vite.config.ts --ssr api/src/vercel-serverless.ts",
    "build:api:cloudflare": "vite build --config api/vite.config.ts --ssr api/src/cloudflare-worker.ts",
    "preview": "nuxt preview",
    "test": "playwright test",
    "test:install": "playwright install chromium",
    "lint": "eslint",
    "postinstall": "nuxt prepare"
  },
  "dependencies": {
    "@mionjs/client": "^0.7.2",
    "@mionjs/core": "^0.7.2",
    "@mionjs/router": "^0.7.2",
    "@mionjs/platform-node": "^0.7.2",
    "@mionjs/platform-bun": "^0.7.2",
    "@mionjs/platform-vercel": "^0.7.2",
    "@mionjs/platform-cloudflare": "^0.7.2",
    "@mionjs/type-formats": "^0.7.2",
    "@nuxt/eslint": "^1.15.2",
    "nuxt": "^4.3.1",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@mionjs/devtools": "^0.8.0",
    "@playwright/test": "^1.58.2",
    "eslint": "^9",
    "vite-node": "^5.3.0",
    "typescript": "^5"
  }
}

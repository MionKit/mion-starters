{
  "name": "@mionjs/create-starter-nextjs",
  "version": "0.2.0",
  "type": "module",
  "bin": {
    "create-starter-nextjs": "./create.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "npm-run-all2 --parallel --race dev:*",
    "dev:next": "next dev",
    "dev:api": "vite-node -c api/vite.config.ts --watch api/src/dev-server.ts",
    "build": "npm-run-all2 build:*",
    "build:api": "vite build --config api/vite.config.ts",
    "build:next": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "playwright test",
    "test:install": "playwright install chromium"
  },
  "dependencies": {
    "@mionjs/client": "0.8.7",
    "@mionjs/core": "0.8.7",
    "@mionjs/drizzle": "0.8.7",
    "@mionjs/platform-bun": "0.8.7",
    "@mionjs/platform-node": "0.8.7",
    "@mionjs/platform-vercel": "0.8.7",
    "@mionjs/router": "0.8.7",
    "@mionjs/type-formats": "0.8.7",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@mionjs/devtools": "0.8.7",
    "@playwright/test": "^1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "npm-run-all2": "^7",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vite": "^7.3.1",
    "vite-node": "^5.3.0"
  }
}

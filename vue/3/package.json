{
  "name": "@mionjs/create-starter-vue",
  "version": "0.2.0",
  "description": "Starter template for building full-stack apps with mion + Vue 3 (SPA). Run `npm create @mionjs/starter-vue <project-name>` to scaffold.",
  "type": "module",
  "license": "MIT",
  "author": "mion",
  "homepage": "https://mion.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mionjs/mion-starters.git",
    "directory": "vue/3"
  },
  "bugs": {
    "url": "https://github.com/mionjs/mion-starters/issues"
  },
  "keywords": [
    "mion",
    "mionjs",
    "vue",
    "vue3",
    "starter",
    "template",
    "create",
    "rpc",
    "api",
    "typescript",
    "spa"
  ],
  "bin": {
    "create-starter-vue": "create.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build:app": "vite build --config vite.app.build.config.ts",
    "build:api": "vite build --config api/vite.config.ts",
    "build": "npm run build:app && npm run build:api",
    "preview": "npm run preview:api & npm run preview:app",
    "preview:app": "vite preview --config vite.app.build.config.ts",
    "preview:api": "node dist/api/server.node.js",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "vitest run && playwright test",
    "test:install": "playwright install chromium",
    "lint": "eslint"
  },
  "dependencies": {
    "@mionjs/client": "file:../../mion-tarballs/mionjs-client.tgz",
    "@mionjs/core": "file:../../mion-tarballs/mionjs-core.tgz",
    "@mionjs/router": "file:../../mion-tarballs/mionjs-router.tgz",
    "@mionjs/platform-node": "file:../../mion-tarballs/mionjs-platform-node.tgz",
    "@mionjs/platform-bun": "file:../../mion-tarballs/mionjs-platform-bun.tgz",
    "@mionjs/platform-vercel": "file:../../mion-tarballs/mionjs-platform-vercel.tgz",
    "@mionjs/platform-cloudflare": "file:../../mion-tarballs/mionjs-platform-cloudflare.tgz",
    "@mionjs/type-formats": "file:../../mion-tarballs/mionjs-type-formats.tgz",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4"
  },
  "devDependencies": {
    "@mionjs/devtools": "file:../../mion-tarballs/mionjs-devtools.tgz",
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^6",
    "eslint": "^9",
    "eslint-plugin-vue": "^10",
    "typescript": "^6",
    "typescript-eslint": "^8",
    "vite": "^7.3.1",
    "vite-node": "^5.3.0",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "@mionjs/client": "file:../../mion-tarballs/mionjs-client.tgz",
    "@mionjs/core": "file:../../mion-tarballs/mionjs-core.tgz",
    "@mionjs/devtools": "file:../../mion-tarballs/mionjs-devtools.tgz",
    "@mionjs/drizzle": "file:../../mion-tarballs/mionjs-drizzle.tgz",
    "@mionjs/platform-aws": "file:../../mion-tarballs/mionjs-platform-aws.tgz",
    "@mionjs/platform-bun": "file:../../mion-tarballs/mionjs-platform-bun.tgz",
    "@mionjs/platform-cloudflare": "file:../../mion-tarballs/mionjs-platform-cloudflare.tgz",
    "@mionjs/platform-gcloud": "file:../../mion-tarballs/mionjs-platform-gcloud.tgz",
    "@mionjs/platform-node": "file:../../mion-tarballs/mionjs-platform-node.tgz",
    "@mionjs/platform-vercel": "file:../../mion-tarballs/mionjs-platform-vercel.tgz",
    "@mionjs/router": "file:../../mion-tarballs/mionjs-router.tgz",
    "@mionjs/run-types": "file:../../mion-tarballs/mionjs-run-types.tgz",
    "@mionjs/type-formats": "file:../../mion-tarballs/mionjs-type-formats.tgz"
  }
}

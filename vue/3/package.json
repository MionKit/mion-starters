{
  "name": "@mionjs/create-starter-vue",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "create-starter-vue": "./create.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "vite",
    "build:app": "vite build --config vite.app.build.config.ts",
    "build:api": "vite build --config api/vite.config.ts",
    "build": "npm run build:app && npm run build:api",
    "preview": "npm run preview:api & npm run preview:app",
    "preview:app": "vite preview --config vite.app.build.config.ts",
    "preview:api": "node dist/api/server.node.js",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "vitest run && playwright test",
    "test:install": "playwright install chromium",
    "lint": "eslint"
  },
  "dependencies": {
    "@mionjs/client": "0.8.6",
    "@mionjs/core": "0.8.6",
    "@mionjs/router": "0.8.6",
    "@mionjs/platform-node": "0.8.6",
    "@mionjs/platform-bun": "0.8.6",
    "@mionjs/platform-vercel": "0.8.6",
    "@mionjs/platform-cloudflare": "0.8.6",
    "@mionjs/type-formats": "0.8.6",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@mionjs/devtools": "0.8.6",
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^6",
    "eslint": "^9",
    "eslint-plugin-vue": "^10",
    "typescript": "^5",
    "typescript-eslint": "^8",
    "vite": "^7.3.1",
    "vite-node": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
